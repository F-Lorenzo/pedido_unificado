# Copia este archivo a .env.local (para pruebas locales) y pega tu API key de NVIDIA.
# Se usa para llamar a DeepSeek V4 Pro servido via NVIDIA NIM (integrate.api.nvidia.com).
# Conseguila en https://build.nvidia.com (creá una cuenta y generá una API key).
# En Vercel cargala en Settings -> Environment Variables con el nombre NVIDIA_API_KEY.
NVIDIA_API_KEY=tu_api_key_aca
